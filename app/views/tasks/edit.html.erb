<%= turbo_frame_tag dom_id(task, "edit"), class: "flex flex-row gap-2 items-center", refresh: "morph" do %>
  <%= form_with model: task, url: project_task_path(project, task) do |f| %>
    <%= f.text_field :name, class: "border-2 border-slate-500 rounded-md", min: 1 %>
    <button class="cursor-pointer">
      <i class="fa-solid fa-floppy-disk text-green-500"></i>
    </button>
  <% end %>

  <%= link_to project_task_path(project), class: "w-4 h-full cursor-pointer flex items-center justify-center" do %>
    <i class="fa-solid fa-xmark text-slate-500 transition-colors hover:text-red-500"></i>
  <% end %>
<% end %>
