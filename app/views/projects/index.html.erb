<div class="flex flex-col gap-4 p-4">
  <% @projects.each do |project| %>
    <div id="<%= dom_id(project) %>" class="flex flex-col bg-white shadow-md rounded-md p-2" data-controller="project">
      <div class="flex flex-row gap-2 items-center">
        <div class="w-4 h-full cursor-pointer flex items-center justify-center" data-action="click->project#toggleTasks">
          <i class="fa-solid fa-caret-right transition-transform" data-project-target="caret"></i>
        </div>

        <%= render template: "projects/show", locals: {project: project} %>

        <%= link_to project_path(project), class: "ml-auto", data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this project?" } do %>
          <div class="w-4 h-full cursor-pointer flex items-center justify-center">
            <i class="fa-solid fa-trash text-slate-800 transition-colors hover:text-red-500"></i>
          </div>
        <% end %>
      </div>

      <div class="hidden" data-project-target="tasks">
        <div class="h-1 bg-slate-300 rounded-md mt-2 mb-2"></div>
        <%= turbo_frame_tag dom_id(project, "tasks"), src: project_tasks_path(project), loading: "lazy", refresh: "morph" do %>
          Loading...
        <% end %>
      </div>
    </div>
  <% end %>
</div>
